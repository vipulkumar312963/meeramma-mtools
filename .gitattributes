# Auto detect text files and perform LF normalization
* text=auto

# Android/Kotlin files
*.kt text eol=lf
*.kts text eol=lf
*.java text eol=lf
*.xml text eol=lf
*.gradle text eol=lf
*.gradle.kts text eol=lf
*.properties text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf

# Git files
.gitattributes text eol=lf
.gitignore text eol=lf

# Binary files (don't convert)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.mp3 binary
*.mp4 binary
*.keystore binary
*.jks binary
*.db binary
*.sqlite binary